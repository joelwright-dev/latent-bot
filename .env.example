# Wallet
PRIVATE_KEY=
POLYMARKET_PROXY_ADDRESS=
POLYGON_RPC_URL=
# 1 = email/magic-link signup (most common), 2 = MetaMask/Gnosis Safe proxy
SIGNATURE_TYPE=1

# Master kill switch — when false, all strategies + monitor pause.
# Toggle via the dashboard header for quick "stop trading, leave running".
BOT_ENABLED=true

# Capital
GAIN_POOL_SPLIT=0.50
MIN_ORDER_SIZE=2.00
TRADING_POOL_PAUSE_THRESHOLD=20.00

# Strategy A
STRATEGY_A_ENABLED=true
STRATEGY_A_DEPLOY_RATE=0.03
STRATEGY_A_MAX_CONCURRENT=3
STRATEGY_A_BID_PRICE=0.90

# Strategy B
STRATEGY_B_ENABLED=true
STRATEGY_B_DEPLOY_RATE=0.15
STRATEGY_B_MAX_POSITION=100.00
STRATEGY_B_BID_PRICE=0.95

# Strategy C (pre-proposal prediction). Scans for markets approaching
# resolution with a strong one-sided price and enters before UMA fires.
# Starts disabled — flip to true once you've seen the dashboard data.
STRATEGY_C_ENABLED=false
STRATEGY_C_DEPLOY_RATE=0.20
STRATEGY_C_MAX_CONCURRENT=2
STRATEGY_C_MAX_POSITION=10.00
STRATEGY_C_HOURS_TO_RESOLUTION=168
STRATEGY_C_ENTRY_PRICE_MIN=0.75
STRATEGY_C_ENTRY_PRICE_MAX=0.98
STRATEGY_C_MIN_VOLUME_24H=100

# Strategy D (copy top weekly traders). Fetches Polymarket's weekly PnL
# leaderboard, filters to ACTIVE traders (recent trade <24h), and mirrors
# their BUYs within slippage tolerance. Undocumented APIs — run
# probe_leaderboard.py first to confirm endpoints alive.
STRATEGY_D_ENABLED=false
STRATEGY_D_DEPLOY_RATE=0.20
STRATEGY_D_MAX_CONCURRENT=2
STRATEGY_D_MAX_POSITION=3.00
STRATEGY_D_MAX_PRICE_SLIPPAGE=0.10
STRATEGY_D_MAX_PRICE_SLIPPAGE_ABS=0.03
STRATEGY_D_MAX_ENTRY_PRICE=0.95         # skip buys above this — 5¢ upside floor
STRATEGY_D_MIN_ENTRY_PRICE=0.25         # skip cheap longshots — 0% historical win rate below this
STRATEGY_D_POLL_SECS=60
STRATEGY_D_COPY_WINDOW_SECS=900
STRATEGY_D_NUM_LEADERS=3                # smaller roster = less exposure to bad copyers
STRATEGY_D_MAX_LEADER_IDLE_HOURS=24
# Leader quality gate: after N settled copies from a leader, block them if
# our win rate on their trades is below the threshold AND we're net negative.
STRATEGY_D_LEADER_MIN_TRADES=10
STRATEGY_D_LEADER_MIN_WIN_RATE=0.30

# Downward-drift guard: skip copies where the ask has fallen below leader's fill.
STRATEGY_D_MAX_PRICE_DOWNWARD=0.05

# Leaderboard lookback. Weekly is noisy; 30d/90d filters out one-hit wonders.
STRATEGY_D_LEADERBOARD_WINDOW=30d
# Min historical trades before we'll follow a leader — proven operators only.
STRATEGY_D_MIN_LEADER_HISTORY=100

# Consensus signal: require N distinct leaders to buy the same token within
# the window. 1 = disable (copy any single leader); 2+ = only act on agreement.
STRATEGY_D_CONSENSUS_LEADERS=1
STRATEGY_D_CONSENSUS_WINDOW_SECS=1800

# Bet-size gating: skip leader trades below this $ — their "speculation" trades.
STRATEGY_D_MIN_LEADER_BET_USDC=100
# Scale our copy size proportional to leader's bet size (within max_position).
STRATEGY_D_SIZE_SCALE_BY_BET=true

# Category specialization: block leaders per-category when their win rate
# there is poor. Requires STRATEGY_D_CATEGORY_FILTER_ENABLED=true.
STRATEGY_D_CATEGORY_FILTER_ENABLED=false
STRATEGY_D_CATEGORY_MIN_TRADES=5
STRATEGY_D_CATEGORY_MIN_WIN_RATE=0.40

# Inverse copy — when true, bet OPPOSITE of leader BUYs. Useful against
# known "fish" leaders with consistently-bad copy history.
STRATEGY_D_INVERSE_COPY=false

# PositionMonitor — auto-exit for Strategy D copy positions.
# Trailing stop tiers (hardcoded in the monitor, only active at peak ≥ 1.5× entry):
#   <5x    → 55% trail (wide — copies on volatile markets need breathing room)
#   5-20x  → 25%
#   20-50x → 15%
#   >50x   → 10%
MONITOR_ENABLED=true
MONITOR_POLL_SECS=30
MONITOR_MAX_LOSS_PCT=0.40               # exit if price < (1 - X) × entry, 0.40 = -40% (tighter than before)
MONITOR_TIMEOUT_HOURS=48                # exit stale positions after N hours
MONITOR_TIMEOUT_MIN_MULTIPLE=2.0        # only timeout if peak × entry < this
MONITOR_PRE_RESOLUTION_HOURS=1.0        # sell in profit if < N hours to resolution
# Defensive tuning — filter flash dips + freshly-opened position noise
MONITOR_CONFIRM_POLLS=3                 # require N consecutive polls below trail (30s × 3 = 90s dwell)
MONITOR_MAX_LOSS_CONFIRM_POLLS=2        # require N consecutive polls below max-loss floor (30s × 2 = 60s dwell; filters single-tick bid wicks)
MONITOR_MIN_HOLD_SECS=7200              # don't monitor freshly-opened positions (2h — matches leader hold times; winners avg 226 min to resolution)
# Trader-exit: if a copied leader sells the same token, we follow them out
MONITOR_TRADER_EXIT_ENABLED=true
MONITOR_TRADER_EXIT_WINDOW_MIN=15       # only follow sells within last N minutes

# Web dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_SECRET=changeme

# Runtime
DB_PATH=latent_bot.db
