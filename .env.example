# Wallet
PRIVATE_KEY=
POLYMARKET_PROXY_ADDRESS=
POLYGON_RPC_URL=
# 1 = email/magic-link signup (most common), 2 = MetaMask/Gnosis Safe proxy
SIGNATURE_TYPE=1

# Master kill switch — when false, all strategies + monitor pause.
# Toggle via the dashboard header for quick "stop trading, leave running".
BOT_ENABLED=true

# Capital
GAIN_POOL_SPLIT=0.50
MIN_ORDER_SIZE=2.00
TRADING_POOL_PAUSE_THRESHOLD=20.00

# Strategy A
STRATEGY_A_ENABLED=true
STRATEGY_A_DEPLOY_RATE=0.03
STRATEGY_A_MAX_CONCURRENT=3
STRATEGY_A_BID_PRICE=0.90

# Strategy B
STRATEGY_B_ENABLED=true
STRATEGY_B_DEPLOY_RATE=0.15
STRATEGY_B_MAX_POSITION=100.00
STRATEGY_B_BID_PRICE=0.95

# Strategy C (pre-proposal prediction). Scans for markets approaching
# resolution with a strong one-sided price and enters before UMA fires.
# Starts disabled — flip to true once you've seen the dashboard data.
STRATEGY_C_ENABLED=false
STRATEGY_C_DEPLOY_RATE=0.20
STRATEGY_C_MAX_CONCURRENT=2
STRATEGY_C_MAX_POSITION=10.00
STRATEGY_C_HOURS_TO_RESOLUTION=168
STRATEGY_C_ENTRY_PRICE_MIN=0.75
STRATEGY_C_ENTRY_PRICE_MAX=0.98
STRATEGY_C_MIN_VOLUME_24H=100

# Strategy D (copy top weekly traders). Fetches Polymarket's weekly PnL
# leaderboard, filters to ACTIVE traders (recent trade <24h), and mirrors
# their BUYs within slippage tolerance. Undocumented APIs — run
# probe_leaderboard.py first to confirm endpoints alive.
STRATEGY_D_ENABLED=false
STRATEGY_D_DEPLOY_RATE=0.20
STRATEGY_D_MAX_CONCURRENT=2
STRATEGY_D_MAX_POSITION=3.00
STRATEGY_D_MAX_PRICE_SLIPPAGE=0.10
STRATEGY_D_MAX_PRICE_SLIPPAGE_ABS=0.03
STRATEGY_D_MAX_ENTRY_PRICE=0.95         # skip buys above this — 5¢ upside floor
STRATEGY_D_MIN_ENTRY_PRICE=0.15         # skip cheap longshots — 0.05-0.15 bucket has been a consistent loser
STRATEGY_D_POLL_SECS=60
STRATEGY_D_COPY_WINDOW_SECS=900
STRATEGY_D_NUM_LEADERS=3                # smaller roster = less exposure to bad copyers
STRATEGY_D_MAX_LEADER_IDLE_HOURS=24
# Leader quality gate: after N settled copies from a leader, block them if
# our win rate on their trades is below the threshold. No net-negative
# escape clause — a 30% win-rate leader whose one lucky moonshot keeps
# them positive is still a bad copy target going forward.
STRATEGY_D_LEADER_MIN_TRADES=5
STRATEGY_D_LEADER_MIN_WIN_RATE=0.45
# Hard blocklist — comma-separated wallet addresses to never copy, regardless of stats.
# Case-insensitive. Use for leaders you know are bad and don't want to wait for
# the gate above to kick in.
STRATEGY_D_LEADER_BLOCKLIST=

# Downward-drift guard: skip copies where the ask has fallen below leader's fill.
STRATEGY_D_MAX_PRICE_DOWNWARD=0.05

# Leaderboard lookback. Weekly is noisy; 30d/90d filters out one-hit wonders.
STRATEGY_D_LEADERBOARD_WINDOW=30d
# Min historical trades before we'll follow a leader — proven operators only.
STRATEGY_D_MIN_LEADER_HISTORY=100

# Consensus signal: require N distinct leaders to buy the same token within
# the window. 1 = disable (copy any single leader); 2+ = only act on agreement.
STRATEGY_D_CONSENSUS_LEADERS=1
STRATEGY_D_CONSENSUS_WINDOW_SECS=1800

# Bet-size gating: skip leader trades below this $ — their "speculation" trades.
STRATEGY_D_MIN_LEADER_BET_USDC=100
# Scale our copy size proportional to leader's bet size (within max_position).
STRATEGY_D_SIZE_SCALE_BY_BET=true

# Category specialization: block leaders per-category when their win rate
# there is poor. Requires STRATEGY_D_CATEGORY_FILTER_ENABLED=true.
STRATEGY_D_CATEGORY_FILTER_ENABLED=false
STRATEGY_D_CATEGORY_MIN_TRADES=5
STRATEGY_D_CATEGORY_MIN_WIN_RATE=0.40

# Inverse copy — when true, bet OPPOSITE of leader BUYs. Useful against
# known "fish" leaders with consistently-bad copy history.
STRATEGY_D_INVERSE_COPY=false

# Strategy E — clear-win sniper, validated by whale behaviour.
# Watches top traders for high-confidence buys near resolution. The
# whole edge: at price ≥ MIN_ENTRY_PRICE on a market resolving within
# MAX_HOURS_TO_RESOLVE, the outcome is mostly decided. Holds to
# auto-redeem — no monitor exits. Per the article ("5 ways to make 100k
# on Polymarket"), $150k+ has been stacked this way at low volatility.
STRATEGY_E_ENABLED=true
STRATEGY_E_POLL_SECS=60
STRATEGY_E_NUM_WHALES=30                # how many top traders to scan
STRATEGY_E_LEADERBOARD_WINDOW=30d       # 7d/30d/90d/all — 30d gives most stable cohort
STRATEGY_E_COPY_WINDOW_SECS=600         # only act on whale trades within last N sec
STRATEGY_E_MIN_ENTRY_PRICE=0.85         # whole edge is "decided"; lower = more candidates + more flip risk
STRATEGY_E_MAX_HOURS_TO_RESOLVE=24.0    # imminent resolution is most of the edge
STRATEGY_E_MAX_POSITION=5.0             # absolute USD cap per snipe
STRATEGY_E_DEPLOY_RATE=0.10             # fraction of pool per snipe
STRATEGY_E_MIN_WHALE_BET_USDC=0.0       # filter tiny tracking trades; 0 = follow every whale BUY regardless of size. Default 0 because allowlisted whales often scale in via $1–$10 fills (iceberg pattern).
STRATEGY_E_MAX_PRICE_SLIPPAGE_ABS=0.02  # don't chase if ask moved up by more than $X since whale fill
# Iceberg dedup: these whales split a single conviction buy across many
# fills (e.g. 24 separate $1–$2k fills on one market in 30 sec). After
# we copy once on a (whale, market), ignore further fills from that
# whale on that market for this many seconds.
STRATEGY_E_PER_TOKEN_COOLDOWN_SECS=3600
# Wallets always tracked, in addition to the leaderboard cohort. The
# leaderboard is "biggest 30d USD profit"; small-bet grinders with
# great win rates never make that list and have to be pinned.
STRATEGY_E_WHALE_ALLOWLIST=0x9b979a065641e8cfde3022a30ed2d9415cf55e12,0x751a2b86cab503496efd325c8344e10159349ea1

# PositionMonitor — auto-exit for Strategy D copy positions.
# Trailing stop tiers (hardcoded in the monitor, only active at peak ≥
# MONITOR_TRAILING_ACTIVATION_GAIN × entry):
#   <5x    → 55% trail (wide — copies on volatile markets need breathing room)
#   5-20x  → 25%
#   20-50x → 15%
#   >50x   → 10%
# After analysing 63 settled trades: every monitor-driven exit was net
# negative (-$45 across max_loss + trailing_stop), while positions that
# ran to auto-redeem paid +$80 (85% win rate). The defaults below are
# loosened to let winners run; monitor now only fires on real crashes.
MONITOR_ENABLED=true
MONITOR_POLL_SECS=30
MONITOR_MAX_LOSS_PCT=0.60               # exit if price < (1 - X) × entry, 0.60 = -60% (loosened from 0.40 — most 40% drops were noise)
MONITOR_TIMEOUT_HOURS=48                # exit stale positions after N hours
MONITOR_TIMEOUT_MIN_MULTIPLE=2.0        # only timeout if peak × entry < this
MONITOR_PRE_RESOLUTION_HOURS=1.0        # sell in profit if < N hours to resolution
# Defensive tuning — filter flash dips + freshly-opened position noise
MONITOR_CONFIRM_POLLS=3                 # require N consecutive polls below trail (30s × 3 = 90s dwell)
MONITOR_MAX_LOSS_CONFIRM_POLLS=5        # require N consecutive polls below max-loss floor (30s × 5 = 150s; filters sustained wicks)
MONITOR_TRAILING_ACTIVATION_GAIN=2.5    # peak must be ≥ this × entry before trailing arms. Raised from 1.5 — every trailing exit at 1.73× peak was a loss.
MONITOR_MIN_HOLD_SECS=7200              # don't monitor freshly-opened positions (2h — matches leader hold times; winners avg 226 min to resolution)
# Trader-exit: if a copied leader sells the same token, we follow them out
MONITOR_TRADER_EXIT_ENABLED=true
MONITOR_TRADER_EXIT_WINDOW_MIN=15       # only follow sells within last N minutes

# Reconciler auto-drift correction
# Settlements credit estimated cashPnl rather than actual on-chain payout, so
# the ledger drifts negative against the wallet over time. The reconciler can
# auto-debit drift each cycle. Capped so a flaky RPC can't nuke the pool.
RECONCILER_AUTO_DRIFT_ENABLED=true
RECONCILER_DRIFT_MIN_CORRECT=0.05       # below this dollar amount, ignore (noise)
RECONCILER_DRIFT_MAX_CORRECT=5.00       # above this single-cycle drift, log + skip → manual review

# Web dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_SECRET=changeme

# Runtime
DB_PATH=latent_bot.db
